#include <iostream>
using namespace std;

class Box {
    int volume;

public:
    Box(int v) {
        volume = v;
    }

    bool operator>(Box b) {
        return volume > b.volume;
    }
};

int main() {
    Box b1(200), b2(150);

    if(b1 > b2)
        cout<<"Box 1 has greater volume";
    else
        cout<<"Box 2 has greater volume";
}
