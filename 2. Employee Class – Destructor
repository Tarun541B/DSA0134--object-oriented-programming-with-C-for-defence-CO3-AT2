#include <iostream>
#include <cstring>
using namespace std;

class Employee {
    char *name;
    double salary;

public:
    Employee(const char *n, double s) {
        name = new char[strlen(n)+1];
        strcpy(name,n);
        salary = s;
        cout<<"Constructor Called"<<endl;
    }

    void display() {
        cout<<"Name: "<<name<<" Salary: "<<salary<<endl;
    }

    ~Employee() {
        delete[] name;
        cout<<"Destructor Called"<<endl;
    }
};

int main() {
    Employee e("Tarun",50000);
    e.display();
}
