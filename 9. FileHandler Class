#include <iostream>
#include <fstream>
using namespace std;

class FileHandler {
    fstream file;

public:
    FileHandler() {
        file.open("sample.txt", ios::out);
        cout<<"File Opened"<<endl;
    }

    ~FileHandler() {
        file.close();
        cout<<"File Closed"<<endl;
    }
};

int main() {
    FileHandler f;
}
